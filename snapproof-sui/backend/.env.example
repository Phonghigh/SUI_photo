# SnapProof backend env. Copy to `.env` and fill in.

# HTTP port the Express server listens on.
PORT=3001

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Sui network: testnet | devnet | mainnet
SUI_NETWORK=testnet

# Deployed SnapProof Move package.
PROOF_PACKAGE_ID=0xf8f5963973c4ca34720937a070eb3e070851f50a2408092496d588574108bf2c

# Optional — if set, the backend connects to Postgres and runs the indexer,
# polling ProofCreated events every INDEXER_POLL_MS and mirroring them locally.
# Leave blank to disable; the in-memory cache serves requests instead.
DATABASE_URL=
INDEXER_POLL_MS=15000

# Optional — Sentry DSN. If set, Sentry is dynamically loaded at startup.
SENTRY_DSN=

# Rate limit for POST endpoints (write paths only).
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX=30
